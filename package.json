{
  "name": "tothemoon",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Interactive Three.js Earth→Moon spacecraft mission theater",
  "scripts": {
    "precompute": "tsx scripts/precompute-trajectory.ts",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/physics/*.test.ts src/mission/*.test.ts",
    "build": "npm run precompute && npm run typecheck && vite build",
    "ci": "npm run typecheck && npm test",
    "preview": "vite preview"
  },
  "dependencies": {
    "three": "^0.178.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/three": "^0.178.0",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
